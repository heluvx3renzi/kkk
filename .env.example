# OpenClaw editor-agent (template) — переменные окружения.
# Заполняются в среде исполнения (Railway / локальный .env). Реальные значения НЕ коммитить.

# Ключ OpenRouter (LLM, формат OpenAI). Нужен для генерации статьи.
OPENROUTER_API_KEY=

# Ключ поиска Tavily. Нужен для поиска источников.
SEARCH_API_KEY=

# Токен Telegram-бота от @BotFather (режим long-polling).
TELEGRAM_BOT_TOKEN=

# ID Telegram-канала для публикации (бот должен быть админом канала с правом публикации).
TELEGRAM_CHANNEL_ID=
